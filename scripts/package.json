{
  "name": "@animeaux/scripts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "generate-image-placeholder": "./bin/generate-image-placeholder.ts"
  },
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "lint": "run-p --continue-on-error --print-label lint:*",
    "lint:eslint": "eslint --cache --cache-location ./node_modules/.cache/eslint --max-warnings 0 .",
    "lint:tsx": "tsc --noEmit",
    "lint-fix": "run-s --print-label lint-fix:eslint",
    "lint-fix:eslint": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix ."
  },
  "devDependencies": {
    "@animeaux/core": "workspace:*",
    "@animeaux/dev-tools": "workspace:*",
    "@types/node": "catalog:",
    "@unpic/pixels": "catalog:",
    "blurhash": "catalog:",
    "dotenv-flow": "catalog:",
    "eslint": "catalog:",
    "npm-run-all": "catalog:",
    "tiny-invariant": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
