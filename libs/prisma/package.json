{
  "name": "@animeaux/prisma",
  "version": "1.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "files": [
    "build"
  ],
  "exports": {
    ".": {
      "types": "./build/src/index.d.ts",
      "default": "./build/src/index.js"
    },
    "./server": {
      "types": "./build/src/index.server.d.ts",
      "default": "./build/src/index.server.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm clean",
    "build": "run-s --print-label build:prisma build:src build:paths",
    "build:paths": "tsc-alias -p ./tsconfig.build.json",
    "build:prisma": "pnpm prisma-env generate",
    "build:src": "tsc -p ./tsconfig.build.json",
    "postbuild": "pnpm sync-workspace",
    "clean": "rm -rf ./build ./src/generated",
    "copy-data": "tsx ./scripts/copy-data.ts",
    "dev": "run-p --continue-on-error --print-label dev:*",
    "dev:paths": "pnpm build:paths --watch",
    "dev:prisma": "chokidar ./schema.prisma --initial --silent -c 'pnpm build:prisma'",
    "dev:src": "pnpm build:src --watch",
    "dev:sync-workspace": "chokidar ./build --debounce --silent -c 'pnpm sync-workspace'",
    "download-all-data": "tsx -r dotenv-flow/config ./scripts/download-all-data.ts",
    "lint": "run-p --continue-on-error --print-label lint:*",
    "lint:eslint": "eslint --cache --cache-location ./node_modules/.cache/eslint --max-warnings 0 .",
    "lint:prettier": "prettier --list-different .",
    "lint:tsc": "tsc --noEmit",
    "lint-fix": "run-s --print-label lint-fix:eslint lint-fix:prettier",
    "lint-fix:eslint": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "lint-fix:prettier": "prettier --write .",
    "migrate": "pnpm prisma-env migrate dev",
    "prisma-env": "NODE_OPTIONS=\"-r dotenv-flow/config\" prisma",
    "reset": "pnpm prisma-env migrate reset -f",
    "studio": "pnpm prisma-env studio",
    "sync-workspace": "# See /docs/decisions/002-workspace-package-injection.md"
  },
  "dependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "@types/react": "catalog:",
    "prisma": "catalog:"
  },
  "devDependencies": {
    "@animeaux/dev-tools": "workspace:*",
    "@animeaux/password": "workspace:*",
    "@faker-js/faker": "catalog:",
    "@types/d3-dsv": "catalog:",
    "@types/luxon": "catalog:",
    "@types/pg": "catalog:",
    "@types/pg-copy-streams": "catalog:",
    "chokidar-cli": "catalog:",
    "d3-dsv": "catalog:",
    "dotenv-flow": "catalog:",
    "eslint": "catalog:",
    "luxon": "catalog:",
    "npm-run-all": "catalog:",
    "pg": "catalog:",
    "pg-copy-streams": "catalog:",
    "prettier": "catalog:",
    "tiny-invariant": "catalog:",
    "tsc-alias": "catalog:",
    "tsx": "catalog:",
    "type-fest": "catalog:",
    "typescript": "catalog:"
  }
}
