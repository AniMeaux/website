{
  "name": "@animeaux/dev-tools",
  "version": "1.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "files": [
    "eslint.config.js",
    "prettier.config.js",
    "reset.d.ts",
    "tsconfig.app.json",
    "tsconfig.base.json",
    "tsconfig.lib.json"
  ],
  "exports": {
    "./eslint": "./eslint.config.js",
    "./prettier": "./prettier.config.js",
    "./reset": "./reset.d.ts",
    "./tsconfig.app": "./tsconfig.app.json",
    "./tsconfig.lib": "./tsconfig.lib.json"
  },
  "scripts": {
    "lint": "run-p --continue-on-error --print-label lint:*",
    "lint:eslint": "eslint --cache --cache-location ./node_modules/.cache/eslint --max-warnings 0 .",
    "lint:prettier": "prettier --list-different .",
    "lint-fix": "run-s --print-label lint-fix:eslint lint-fix:prettier",
    "lint-fix:eslint": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "lint-fix:prettier": "prettier --write ."
  },
  "optionalDependencies": {
    "prettier-plugin-tailwindcss": "catalog:"
  },
  "dependencies": {
    "@total-typescript/ts-reset": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-better-tailwindcss": "catalog:",
    "eslint-plugin-import-x": "catalog:",
    "eslint-plugin-jsx-a11y": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "devDependencies": {
    "npm-run-all": "catalog:"
  }
}
