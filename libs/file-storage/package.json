{
  "name": "@animeaux/file-storage",
  "version": "1.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/src/index.d.ts",
      "default": "./build/src/index.js"
    },
    "./server": {
      "types": "./build/src/index.server.d.ts",
      "default": "./build/src/index.server.js"
    }
  },
  "scripts": {
    "prebuild": "pnpm clean",
    "build": "run-s --print-label build:src build:paths",
    "build:paths": "tsc-alias -p ./tsconfig.build.json",
    "build:src": "tsc -p ./tsconfig.build.json",
    "clean": "rm -rf ./build",
    "dev": "run-p --continue-on-error --print-label dev:*",
    "dev:paths": "pnpm build:paths --watch",
    "dev:src": "pnpm build:src --watch",
    "lint": "run-p --continue-on-error --print-label lint:*",
    "lint:eslint": "eslint --cache --cache-location ./node_modules/.cache/eslint --max-warnings 0 .",
    "lint:prettier": "prettier --list-different .",
    "lint:tsc": "tsc --noEmit",
    "lint-fix": "run-s --print-label lint-fix:eslint lint-fix:prettier",
    "lint-fix:eslint": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "lint-fix:prettier": "prettier --write ."
  },
  "dependencies": {
    "@animeaux/core": "workspace:*",
    "@animeaux/zod-utils": "workspace:*",
    "@mjackson/form-data-parser": "catalog:",
    "@mjackson/lazy-file": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/core": "catalog:",
    "@opentelemetry/instrumentation": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "@remix-run/node": "catalog:",
    "@remix-run/react": "catalog:",
    "@sentry/remix": "catalog:",
    "googleapis": "catalog:",
    "uuid": "catalog:",
    "react": "catalog:"
  },
  "devDependencies": {
    "@animeaux/dev-tools": "workspace:*",
    "@total-typescript/ts-reset": "catalog:",
    "@types/node": "catalog:",
    "@types/uuid": "catalog:",
    "eslint": "catalog:",
    "npm-run-all": "catalog:",
    "prettier": "catalog:",
    "tsc-alias": "catalog:",
    "typescript": "catalog:"
  }
}
