# This file only contains environment variables for local development.
# To create local overrides, create a file named `.env.local` in the same
# folder.

# -- Core ----------------------------------------------------------------------

APPLICATION_TOKEN=admin-token
PUBLIC_HOST=http://admin.animeaux.localhost
RUNTIME_ENV=local
SESSION_SECRET=session-secret

# -- Services ------------------------------------------------------------------

CLOUDINARY_API_KEY=mock-api-key
CLOUDINARY_API_SECRET=mock-api-secret
CLOUDINARY_CLOUD_NAME=mock-cloud-name

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# GOOGLE_API_CLIENT_EMAIL=
# GOOGLE_API_PRIVATE_KEY=
GOOGLE_DRIVE_ROOT_FOLDER_ID=root-folder-id

# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=

SHOW_URL=http://show.animeaux.localhost

# Can't use custom host name
SHOW_NOTIFICATION_ENDPOINT=http://localhost:3001/api/notification

# -- Feature flags -------------------------------------------------------------

ENABLE_CRONS=false
FEATURE_FLAG_ANIMAL_TEXT_SEARCH_MODE=fuzzy

PRICE_ADDITIONAL_BRACELET=2
PRICE_BREAKFAST_PER_PERSON_PER_DAY=3
PRICE_CORNER_STAND=25
PRICE_DIVIDER=5
PRICE_TABLE_CLOTHS=1
