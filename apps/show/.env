# This file only contains environment variables for local development.
# To create local overrides, create a file named `.env.local` in the same
# folder.

# -- Core ----------------------------------------------------------------------

PUBLIC_HOST=http://show.animeaux.localhost
RUNTIME_ENV=local

# -- Services ------------------------------------------------------------------

ANIMEAUX_URL=http://animeaux.localhost

APPLICATION_TOKEN_ADMIN=admin-token

CARPOOL_FACEBOOK_GROUP_URL=?carpool-facebook-group-url

CLOUDINARY_API_KEY=mock-api-key
CLOUDINARY_API_SECRET=mock-api-secret
CLOUDINARY_CLOUD_NAME=mock-cloud-name

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

FACEBOOK_URL=?facebook-url

# GOOGLE_API_CLIENT_EMAIL=
# GOOGLE_API_PRIVATE_KEY=
GOOGLE_DRIVE_APPLICATION_FOLDER_ID=application-folder-id
GOOGLE_DRIVE_SHARED_FOLDER_ID=shared-folder-id

# GOOGLE_TAG_MANAGER_ID=

INSTAGRAM_URL=?instagram-url

PRESS_RELEASE_URL=?press-release-url

# RESEND_API_KEY=
# RESEND_USE_REAL_EMAIL=

# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=

SPONSORSHIP_URL=?sponsorship-url

# Don't use hash so it doesn't appear active in navigation.
TICKETING_URL=https://ticketing.url

# -- Feature flags -------------------------------------------------------------

APPLICATION_VALIDATION_START_DATE=2025-10-01

FEATURE_FLAG_EXHIBITOR_APPLICATION_ONLINE=true
FEATURE_FLAG_SHOW_EXHIBITORS=true
FEATURE_FLAG_SHOW_ON_STAND_ANIMATIONS=true
FEATURE_FLAG_SHOW_PROGRAM=true
FEATURE_FLAG_SHOW_PROVIDERS=true
FEATURE_FLAG_SHOW_SPONSORS=true
FEATURE_FLAG_SITE_ONLINE=true

PRICE_ADDITIONAL_BRACELET=2
PRICE_BREAKFAST_PER_PERSON_PER_DAY=3
PRICE_CORNER_STAND=25
PRICE_DIVIDER=5
PRICE_TABLE_CLOTHS=1
